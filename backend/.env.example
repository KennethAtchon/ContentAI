# =============================================================================
# ReelStudio — backend `.env`
# =============================================================================
# Copy to `backend/.env`. Required keys are marked **REQUIRED** below.
#
# `docker compose up` overrides `DATABASE_URL` and `REDIS_URL` to use the
# `postgres` and `redis` services; values here still document the shape and are
# used when running the API outside Docker (e.g. `bun run dev` on the host).
# =============================================================================

# ─── Environment ───────────────────────────────────────────────────────────────
NODE_ENV=development
APP_ENV=development
PORT=3001

# ─── Database ──────────────────────────────────────────────────────────────────
# Local Docker (Compose overrides): postgres service + `contentAI` database
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/contentAI?sslmode=disable
ENABLE_DB_HEALTH_CHECKS=false

# ─── Redis ─────────────────────────────────────────────────────────────────────
# Local Docker (Compose overrides): `redis` service
REDIS_URL=redis://redis:6379

# ─── Firebase Client (REQUIRED — server reads these) ───────────────────────────
FIREBASE_API_KEY=your_firebase_api_key
FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_STORAGE_BUCKET=your_project.appspot.com
FIREBASE_MESSAGING_SENDER_ID=your_sender_id
FIREBASE_APP_ID=your_app_id

# ─── Firebase Admin (REQUIRED) ───────────────────────────────────────────────────
FIREBASE_CLIENT_EMAIL=your_client_email@your_project_id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour_Private_Key_Here\n-----END PRIVATE KEY-----\n"

# ─── Security (CSRF_SECRET REQUIRED) ───────────────────────────────────────────
# Must be exactly 64 hex characters (32 bytes). Generate: openssl rand -hex 32
CSRF_SECRET=
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
ADMIN_SPECIAL_CODE_HASH=

# ─── Cloudflare R2 (optional — leave blank if unused) ─────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# ─── Stripe (optional for local dev) ───────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ─── Email / Resend (optional for local dev) ─────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@yourdomain.com
RESEND_REPLY_TO_EMAIL=support@yourdomain.com

# ─── Application ───────────────────────────────────────────────────────────────
BASE_URL=http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ─── Observability ───────────────────────────────────────────────────────────────
METRICS_ENABLED=false
METRICS_SECRET=

# ─── Logging ───────────────────────────────────────────────────────────────────
DEBUG_ENABLED=false
LOG_LEVEL=info

# ─── AI (optional — mock mode covers many flows without keys) ──────────────────
ANTHROPIC_API_KEY=
ANALYSIS_MODEL=claude-haiku-4-5-20251001
GENERATION_MODEL=claude-sonnet-4-6
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPEN_ROUTER_KEY=
OPEN_ROUTER_MODEL=google/gemini-2.0-flash-lite-001

# ─── Reels / outbound integrations (optional when mock is on) ──────────────────
REEL_SOURCE=manual
SOCIAL_API_KEY=
INSTAGRAM_API_TOKEN=
VIRAL_VIEWS_THRESHOLD=100000

# Mock outbound integrations: fixture reels, video clips, TTS (see `backend/fixtures/media/`).
# In development, defaults to ON when unset (see `envUtil.ts`). Compose sets it on the
# backend container via root `.env` / `DEV_MOCK_EXTERNAL_INTEGRATIONS` (default true).
# Optional: set DEV_MOCK_VIDEO_CLIP_DELAY_MS=0 for instant mocked clips in tests.
# DEV_MOCK_VIDEO_CLIP_DELAY_MS=15000

# ─── Cron ────────────────────────────────────────────────────────────────────────
CRON_JOBS_ENABLED=false

# ─── Testing / CI ───────────────────────────────────────────────────────────────
E2E_BASE_URL=http://localhost:3000

# ─── Deployment (Railway) ───────────────────────────────────────────────────────
# RAILWAY_PUBLIC_DOMAIN=your-app.up.railway.app
