# Backend Environment Variables
# Copy this file to .env and fill in your actual values

# ─── Environment ───────────────────────────────────────────────────────────────
NODE_ENV=development
APP_ENV=development        # "development" | "production" | "test"
PORT=3001

# ─── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/contentAI?sslmode=disable
ENABLE_DB_HEALTH_CHECKS=false    # Enable slow-query monitoring (disable in CI)

# ─── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ─── Firebase Client (used for Firestore queries in route handlers) ─────────────
FIREBASE_API_KEY=your_firebase_api_key
FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_STORAGE_BUCKET=your_project.appspot.com
FIREBASE_MESSAGING_SENDER_ID=your_sender_id
FIREBASE_APP_ID=your_app_id

# ─── Firebase Admin (server-side only) ─────────────────────────────────────────
FIREBASE_CLIENT_EMAIL=your_client_email@your_project_id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour_Private_Key_Here\n-----END PRIVATE KEY-----\n"

# ─── Cloudflare R2 Storage ─────────────────────────────────────────────────────
R2_ACCOUNT_ID=your_account_id
R2_ACCESS_KEY_ID=your_access_key_id
R2_SECRET_ACCESS_KEY=your_secret_access_key
R2_BUCKET_NAME=your_bucket_name
R2_PUBLIC_URL=https://your-bucket.your-account.r2.cloudflarestorage.com
R2_ENABLED=true

# ─── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret


# ─── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM_EMAIL=noreply@yourdomain.com
RESEND_REPLY_TO_EMAIL=support@yourdomain.com

# ─── Security ──────────────────────────────────────────────────────────────────
ENCRYPTION_KEY=your_32_character_encryption_key_here
ADMIN_SPECIAL_CODE_HASH=your_hashed_admin_code
CSRF_SECRET=your_csrf_secret_min_32_chars

# ─── Application ───────────────────────────────────────────────────────────────
BASE_URL=https://yourdomain.com    # Used for Stripe redirect URLs; falls back to request origin

# ─── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins in production
CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ─── Observability / Prometheus ────────────────────────────────────────────────
METRICS_ENABLED=true               # Enable GET /api/metrics (default: true in production)
METRICS_SECRET=your_metrics_bearer_token   # Bearer token for Grafana Cloud scraper; leave blank to disable auth

# ─── Logging ───────────────────────────────────────────────────────────────────
DEBUG_ENABLED=false
LOG_LEVEL=info    # "debug" | "info" | "warn" | "error"

# ─── AI / Anthropic Claude ─────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your_anthropic_api_key
ANALYSIS_MODEL=claude-haiku-4-5-20251001    # Model used for structural analysis (default: claude-haiku-4-5-20251001)
GENERATION_MODEL=claude-sonnet-4-6          # Model used for content generation (default: claude-sonnet-4-6)

# ─── AI / OpenAI ───────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your_openai_api_key
OPENAI_MODEL=gpt-4o-mini                    # OpenAI model for scraper remix suggestions

# ─── Reels / Content Platform ──────────────────────────────────────────────────
REEL_SOURCE=manual                    # "manual" | "apify" | "instagram_api"
SOCIAL_API_KEY=your_apify_api_key     # Apify or third-party social scraper API key
INSTAGRAM_API_TOKEN=your_instagram_graph_api_token  # Meta Instagram Graph API token (Phase 2+)
VIRAL_VIEWS_THRESHOLD=100000          # Minimum views to classify a Reel as viral
DEV_USE_MOCK_REEL_SCRAPE=true         # Development-only: use hardcoded 10-reel fixture and repeat to requested limit instead of external scrape APIs

# ─── Cron Jobs ───────────────────────────────────────────────────────────────────
CRON_JOBS_ENABLED=false            # Enable scheduled background jobs (daily scan, etc.). Default: true in production, false in development

# ─── Testing & CI ───────────────────────────────────────────────────────────────
E2E_BASE_URL=http://localhost:3000

# ─── Deployment (Railway) ───────────────────────────────────────────────────────
# Set automatically by Railway — do not set manually in development
# RAILWAY_PUBLIC_DOMAIN=your-app.up.railway.app

OPEN_ROUTER_KEY=1111
OPEN_ROUTER_MODEL=openai/gpt-4o-mini
