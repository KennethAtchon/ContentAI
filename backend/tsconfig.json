{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "rootDir": "..",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "jsx": "react-jsx",
    "lib": ["ESNext", "DOM"],
    "types": ["bun-types"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "zod": ["./node_modules/zod"]
    },
    "outDir": "./dist"
  },
  "include": [
    "src/**/*.ts",
    "scripts/seed-mock-reels.ts",
    "scripts/seed-voice-previews.ts"
  ],
  "exclude": ["node_modules", "dist", "__tests__"]
}
