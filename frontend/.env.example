# =============================================================================
# ReelStudio — frontend `.env` (Vite)
# =============================================================================
# Copy to `frontend/.env`. Keys marked **REQUIRED** must be set for the app to run.
# =============================================================================

NODE_ENV=development

# ─── API base URL (REQUIRED for predictable behavior) ─────────────────────────
# Local Docker: backend is published on host port 3001 — use `http://localhost:3001`
#   (`docker-compose.yml` sets this for the frontend container if you use root `.env`).
# Native dev (`bun run dev` on host): use `http://localhost:3000` so requests go
#   through the Vite dev server, which proxies `/api` to the backend on 3001.
VITE_API_URL=http://localhost:3001

# ─── Firebase (REQUIRED — client SDK) ───────────────────────────────────────────
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=

# ─── Stripe (REQUIRED — publishable key) ────────────────────────────────────────
VITE_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key

# ─── Optional ────────────────────────────────────────────────────────────────────
VITE_SENTRY_DSN=

# ─── App metadata ───────────────────────────────────────────────────────────────
VITE_APP_NAME=ReelStudio
VITE_APP_URL=http://localhost:3000
