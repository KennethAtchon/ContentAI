# =============================================================================
# ReelStudio — root `.env` for Docker Compose (local hosting)
# =============================================================================
# Copy to `.env` in this directory: `cp .env.example .env`
#
# Compose loads this file for variable substitution and passes it to services
# (`env_file:`). Use it for infrastructure + Docker-only overrides.
#
# App secrets live in `backend/.env` and `frontend/.env` (see those `.env.example`
# files). Required keys for a working stack are listed there.
# =============================================================================

# ─── Required for local Docker (database container) ─────────────────────────────
POSTGRES_DB=contentAI
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# ─── Optional: local Docker defaults ──────────────────────────────────────────────
NODE_ENV=development

# Used in URLs when you open the app from your machine (browser on host)
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:3001

# Mock outbound integrations (fixtures for reel scrape, video clips, TTS).
# Default true for local Docker. Set to false here (root `.env`) to use real APIs
# (requires keys in `backend/.env` and `DEV_MOCK_EXTERNAL_INTEGRATIONS` is applied
# by Compose to the backend container).
DEV_MOCK_EXTERNAL_INTEGRATIONS=true

# Browser → host-published backend port (see `docker-compose.yml` `frontend.environment`)
VITE_API_URL=http://localhost:3001

# ─── Production / nginx profile only (not needed for default local dev) ─────────
# DOMAIN_NAME=localhost
# SSL_CERT_PATH=./nginx/ssl/cert.pem
# SSL_KEY_PATH=./nginx/ssl/key.pem
